        long_stocks="HSY, MDLZ, GIS",
        short_stocks="",
        long_etfs="",
        short_etfs=""
    )

# 7. Texas heat revision
texas_temp_revision = float(weather.get("texas_temp_revision", 0))
if texas_temp_revision >= 2.0:
    add_signal(
        region="Texas",
