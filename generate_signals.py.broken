import pandas as pdnano generate_signals.pyimport pandas as pd

weather_df = pd.read_csv("weather_values.csv")
weather = dict(zip(weather_df["metric"], weather_df["value"]))

signals = []

def add_signal(region, signal, market, raw_strength,
               affected_area, affected_industries,
               weather_reason, market_reason,
               recommendation, stock, etf, futures,
               confidence, risk,
               commodity_weight, equity_weight,
               long_stocks="", short_stocks="",
               long_etfs="", short_etfs=""):
    weather_score = round(abs(raw_strength), 2)
    commodity_score = round(abs(raw_strength) * commodity_weight, 2)
    equity_etf_score = round(abs(raw_strength) * equity_weight, 2)

    trade_raw = (
        weather_score * 0.25 +
        commodity_score * 0.45 +
        equity_etf_score * 0.30
    )
    trade_score = min(10, round(trade_raw / 5, 1))

    signals.append({
        "Region": region,
        "WeatherSignal": signal,
        "Market": market,
        "AffectedArea": affected_area,
        "AffectedIndustries": affected_industries,
        "SignalStrength": weather_score,
        "WeatherScore": weather_score,
        "CommodityScore": commodity_score,
        "EquityETFScore": equity_etf_score,
        "TradeScore": trade_score,
        "WeatherReasoning": weather_reason,
        "MarketReasoning": market_reason,
        "Recommendation": recommendation,
        "StockIdea": stock,
        "ETFIdea": etf,
        "FuturesIdea": futures,
        "LongStocks": long_stocks,
        "ShortStocks": short_stocks,
        "LongETFs": long_etfs,
        "ShortETFs": short_etfs,
        "Confidence": confidence,
        "ModelSource": "area_exposure_model",
        "RiskNote": risk
    })

# 1. NW Europe colder revision
nw_europe_temp_revision = float(weather.get("nw_europe_temp_revision", 0))
if nw_europe_temp_revision <= -2.0:
    add_signal(
        region="NW Europe",
        signal="Cooling revision",
        market="Gas / Power",
        raw_strength=nw_europe_temp_revision,
        affected_area="Northwest Europe",
        affected_industries="Natural gas, power generation, utilities, heating demand",
        weather_reason=f"Forecast temperatures shifted lower by {nw_europe_temp_revision:.1f}°C across Northwest Europe.",
        market_reason="Colder weather in Northwest Europe can increase heating demand and support gas and power-sensitive assets.",
        recommendation="BUY / WATCH",
        stock="LNG",
        etf="UNG",
        futures="Natural Gas Futures",
        confidence="Medium",
        risk="US gas proxies are imperfect for European gas exposure.",
        commodity_weight=3.5,
        equity_weight=1.8,
        long_stocks="LNG, SHEL, BP",
        short_stocks="",
        long_etfs="UNG",
        short_etfs=""
    )

# 2. Brazil coffee wetter shift
brazil_rain_revision = float(weather.get("brazil_rain_revision", 0))
if brazil_rain_revision >= 4.0:
    add_signal(
        region="Brazil Coffee Belt",
        signal="Wetter shift",
        market="Coffee",
        raw_strength=brazil_rain_revision,
        affected_area="Brazil coffee-growing regions",
        affected_industries="Coffee supply chain, coffee futures, beverage input costs",
        weather_reason=f"Rainfall forecasts improved by {brazil_rain_revision:.1f} mm across Brazil coffee regions.",
        market_reason="Improved rainfall can reduce crop stress and weaken bullish coffee pressure.",
        recommendation="AVOID / SELL / WATCH",
        stock="SBUX",
        etf="JO",
        futures="Coffee Futures",
        confidence="Low",
        risk="Coffee also depends on inventories, FX and crop reports.",
        commodity_weight=2.5,
        equity_weight=0.8,
        long_stocks="",
        short_stocks="SBUX",
        long_etfs="",
        short_etfs="JO"
    )

# 3. US Corn Belt hot/dry
cornbelt_hotdry_score = float(weather.get("cornbelt_hotdry_score", 0))
if cornbelt_hotdry_score >= 4.0:
    add_signal(
        region="US Corn Belt",
        signal="Hot and Dry",
        market="Corn",
        raw_strength=cornbelt_hotdry_score,
        affected_area="US Corn Belt",
        affected_industries="Corn, fertilizers, agribusiness, crop inputs",
        weather_reason=f"Hot-dry stress score reached {cornbelt_hotdry_score:.1f}.",
        market_reason="Higher crop stress in the Corn Belt can support corn prices and crop-linked names.",
        recommendation="BUY / WATCH",
        stock="ADM",
        etf="CORN",
        futures="Corn Futures",
        confidence="Medium",
        risk="Most important during active growing season.",
        commodity_weight=3.8,
        equity_weight=1.9,
        long_stocks="ADM, BG, MOS, NTR, CF",
        short_stocks="",
        long_etfs="CORN, MOO",
        short_etfs=""
    )

# 4. US Wheat Plains drought
us_wheat_drought_score = float(weather.get("us_wheat_drought_score", 0))
if us_wheat_drought_score >= 3.5:
    add_signal(
        region="US Wheat Plains",
        signal="Drought stress",
        market="Wheat",
        raw_strength=us_wheat_drought_score,
        affected_area="US Wheat Plains",
        affected_industries="Wheat, grain trading, fertilizers, farm inputs",
        weather_reason=f"Wheat plains drought score reached {us_wheat_drought_score:.1f}.",
        market_reason="Drier wheat areas can support wheat prices and grain-sensitive names.",
        recommendation="BUY / WATCH",
        stock="BG",
        etf="WEAT",
        futures="Wheat Futures",
        confidence="Medium",
        risk="Timing matters a lot relative to crop stage.",
        commodity_weight=3.6,
        equity_weight=1.7,
        long_stocks="BG, ADM, MOS, NTR, CF",
        short_stocks="",
        long_etfs="WEAT, MOO",
        short_etfs=""
    )

# 5. Argentina soy dryness
argentina_soy_dryness = float(weather.get("argentina_soy_dryness", 0))
if argentina_soy_dryness >= 3.5:
    add_signal(
        region="Argentina Pampas",
        signal="Dryness stress",
        market="Soy",
        raw_strength=argentina_soy_dryness,
        affected_area="Argentina Pampas",
        affected_industries="Soybeans, agribusiness, fertilizers, crop inputs",
        weather_reason=f"Argentina soy dryness score reached {argentina_soy_dryness:.1f}.",
        market_reason="Drier Pampas conditions can support soybean prices and input-sensitive names.",
        recommendation="BUY / WATCH",
        stock="BG",
        etf="SOYB",
        futures="Soybean Futures",
        confidence="Medium",
        risk="South American crop/weather timing matters.",
        commodity_weight=3.7,
        equity_weight=1.8,
        long_stocks="BG, ADM, MOS, NTR, CF",
        short_stocks="",
        long_etfs="SOYB, MOO",
        short_etfs=""
    )

# 6. West Africa cocoa rainfall shortfall
west_africa_cocoa_rain = float(weather.get("west_africa_cocoa_rain", 0))
if west_africa_cocoa_rain <= -3.0:
    add_signal(
        region="West Africa Cocoa Belt",
        signal="Rainfall shortfall",
        market="Cocoa",
        raw_strength=west_africa_cocoa_rain,
